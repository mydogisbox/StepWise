{
  "name": "NestedWorkflow_PlaceOrder",
  "steps": [
    {
      "workflow": "SetupUser"
    },
    {
      "build": "addOrderItem"
    },
    {
      "step": "createOrder"
    }
  ],
  "assertions": [
