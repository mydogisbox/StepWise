{
  "steps": {
    "createUser": {
      "target": "sample-api",
      "method": "POST",
      "path": "/users",
      "headers": {
        "Authorization": { "template": "Bearer {login.token}" }
      },
      "defaults": {
        "email":     { "generated": "email" },
        "firstName": { "static": "Test" },
        "lastName":  { "static": "User" },
        "role":      { "static": "user" }
      }
    },
    "addOrderItem": {
      "accumulateAs": "orderItems",
      "defaults": {
        "productName": { "static": "Widget" },
        "quantity":    { "static": 1 },
        "unitPrice":   { "static": 9.99 }
      }
    },
    "createOrder": {
      "target": "sample-api",
      "method": "POST",
      "path": "/orders",
      "headers": {
        "Authorization": { "template": "Bearer {login.token}" }
      },
      "defaults": {
        "userId": { "from": "createUser.id" },
        "items":  { "from": "orderItems" }
      }
    },
    "getOrder": {
      "target": "sample-api",
      "method": "GET",
      "path": "/orders/{orderId}",
      "headers": {
        "Authorization": { "template": "Bearer {login.token}" }
      },
      "pathParams": {
        "orderId": { "from": "createOrder.id" }
      }
    }
  }
}
