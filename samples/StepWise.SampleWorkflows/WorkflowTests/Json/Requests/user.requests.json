{
  "steps": {
    "getUsers": {
      "target": "sample-api",
      "method": "GET",
      "path": "/users",
      "auth": { "type": "bearer", "from": "login.token" },
      "query": {
        "role": { "static": "user" }
      }
    },
    "updateUserAddress": {
      "target": "sample-api",
      "method": "PUT",
      "path": "/users/{userId}/address",
      "auth": { "type": "bearer", "from": "login.token" },
      "pathParams": {
        "userId": { "from": "createUser.id" }
      },
      "defaults": {
        "contact": { "static": {
          "primary": { "static": {
            "address": { "static": {
              "street":  { "static": "123 Main St" },
              "city":    { "static": "Springfield" },
              "region":  { "static": {
                "state":   { "static": "IL" },
                "country": { "static": "US" }
              }}
            }}
          }}
        }}
      }
    }
  }
}
