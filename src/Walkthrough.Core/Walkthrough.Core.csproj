    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="build\Walkthrough.Core.targets">
      <Pack>true</Pack>
      <PackagePath>build/Walkthrough.Core.targets</PackagePath>
