    <Content Include="..\..\docs\claude\json-style.md">
      <Pack>true</Pack>
      <PackagePath>build/claude/json-style.md</PackagePath>
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
